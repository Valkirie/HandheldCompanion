<Page
    x:Class="HandheldCompanion.Views.Pages.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:l="clr-namespace:HandheldCompanion.Localization"
    xmlns:managers="clr-namespace:HandheldCompanion.Managers;assembly=HandheldCompanion"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:HandheldCompanion.Properties"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels"
    Name="Profiles"
    Title="{l:Static resx:Resources.ProfilesPage_Profiles}"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:ProfilesPageViewModel}"
    d:DesignHeight="4000"
    d:DesignWidth="1000"
    KeepAlive="True"
    mc:Ignorable="d">

    <Grid Name="MainGrid" Margin="20">
        <Image
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Opacity="0"
            Source="{Binding Artwork, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, NotifyOnTargetUpdated=True}"
            Stretch="Uniform">
            <Image.Triggers>
                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                    <BeginStoryboard>
                        <Storyboard>
                            <!--  fade in from 0->1 in 300ms  -->
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                From="0"
                                To="0.6"
                                Duration="0:0:0.3" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Image.Triggers>
            <Image.OpacityMask>
                <RadialGradientBrush Center="0.8,0.4" GradientOrigin="0.8,0.4" RadiusX="0.8" RadiusY="1.2">
                    <GradientStop Offset="0.0" Color="{DynamicResource MaskGradientStartColor}" />
                    <GradientStop Offset="0.4" Color="{DynamicResource MaskGradientEndColor}" />
                </RadialGradientBrush>
            </Image.OpacityMask>
        </Image>

        <StackPanel>
            <ui:ContentDialog
                Name="IGGBDialog"
                CloseButtonText="Close"
                IsEnabled="{Binding IsLibraryConnected, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                <Grid>
                    <ui:ProgressRing
                        Panel.ZIndex="1"
                        IsIndeterminate="True"
                        Visibility="{Binding IsLibraryBusy, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <ikw:SimpleStackPanel
                        Width="500"
                        IsEnabled="{Binding IsLibraryBusy, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InvertBooleanConverter}}"
                        Spacing="12">
                        <ikw:SimpleStackPanel Spacing="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="9*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    ui:ControlHelper.PlaceholderText="Search"
                                    Text="{Binding LibrarySearchField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="1"
                                    Margin="6,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding RefreshLibrary}"
                                    Content="Search" />
                            </Grid>

                            <ComboBox
                                MaxHeight="170"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{Binding HasLibraryEntry, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{Binding LibraryPickers, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedIndex="{Binding SelectedLibraryIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                                <ComboBox.ItemContainerStyle>
                                    <Style BasedOn="{StaticResource {x:Type ComboBoxItem}}" TargetType="ComboBoxItem">
                                        <Setter Property="ToolTip" Value="{Binding Description}" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource BodyTextBlockStyle}"
                                                Text="{Binding Name}"
                                                TextWrapping="Wrap" />

                                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{Binding Family}" />
                                                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text=" - " />
                                                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{Binding ReleaseDateYear}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding QuerySteamGrid}">SteamGrid</CheckBox>
                                <CheckBox IsChecked="{Binding QueryIGDB}">IGDB</CheckBox>
                            </StackPanel>

                            <ikw:SimpleStackPanel Spacing="3" Visibility="{Binding HasLibraryEntry, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="Preview" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <ui:FlipView
                                            x:Name="FlipViewCovers"
                                            Height="180"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding LibraryCovers, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectedIndex="{Binding LibraryCoversIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ui:FlipView.ItemTemplate>
                                                <DataTemplate>
                                                    <Image
                                                        HorizontalAlignment="Center"
                                                        Source="{Binding Image, Mode=OneWay}"
                                                        Stretch="UniformToFill" />
                                                </DataTemplate>
                                            </ui:FlipView.ItemTemplate>
                                        </ui:FlipView>

                                        <ui:PipsPager
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            IsEnabled="False"
                                            MaxVisiblePips="6"
                                            NextButtonVisibility="Collapsed"
                                            NumberOfPages="{Binding LibraryCovers.Count}"
                                            PreviousButtonVisibility="Collapsed"
                                            SelectedPageIndex="{Binding SelectedIndex, ElementName=FlipViewCovers, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <ui:FlipView
                                            x:Name="FlipViewArtworks"
                                            Height="180"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding LibraryArtworks, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectedIndex="{Binding LibraryArtworksIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ui:FlipView.ItemTemplate>
                                                <DataTemplate>
                                                    <Image
                                                        HorizontalAlignment="Center"
                                                        Source="{Binding Image, Mode=OneWay}"
                                                        Stretch="UniformToFill" />
                                                </DataTemplate>
                                            </ui:FlipView.ItemTemplate>
                                        </ui:FlipView>

                                        <ui:PipsPager
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            IsEnabled="False"
                                            MaxVisiblePips="6"
                                            NextButtonVisibility="Collapsed"
                                            NumberOfPages="{Binding LibraryArtworks.Count}"
                                            PreviousButtonVisibility="Collapsed"
                                            SelectedPageIndex="{Binding SelectedIndex, ElementName=FlipViewArtworks, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>

                                <Button
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding DownloadLibrary}"
                                    Content="Update metadata"
                                    IsEnabled="{Binding HasLibraryEntry, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{DynamicResource AccentButtonStyle}" />
                            </ikw:SimpleStackPanel>
                        </ikw:SimpleStackPanel>
                    </ikw:SimpleStackPanel>
                </Grid>
            </ui:ContentDialog>

            <ui:ContentDialog
                Name="ProfileRenameDialog"
                CloseButtonClick="ProfileRenameDialog_CloseButtonClick"
                CloseButtonText="{l:Static resx:Resources.ProfilesPage_Dialogue_Cancel}"
                PrimaryButtonClick="ProfileRenameDialog_PrimaryButtonClick"
                PrimaryButtonText="{l:Static resx:Resources.ProfilesPage_Dialogue_Rename}">
                <ikw:SimpleStackPanel MinWidth="500" Spacing="12">
                    <ikw:SimpleStackPanel Spacing="3">
                        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_ProfileRenamingDialogue_Name}" />
                        <TextBox x:Name="ProfileNameTextBox" HorizontalAlignment="Stretch" />
                    </ikw:SimpleStackPanel>
                </ikw:SimpleStackPanel>
            </ui:ContentDialog>

            <ui:ContentDialog
                Name="SubProfileRenameDialog"
                CloseButtonClick="SubProfileRenameDialog_CloseButtonClick"
                CloseButtonText="{l:Static resx:Resources.ProfilesPage_Dialogue_Cancel}"
                PrimaryButtonClick="SubProfileRenameDialog_PrimaryButtonClick"
                PrimaryButtonText="{l:Static resx:Resources.ProfilesPage_Dialogue_Rename}">
                <ikw:SimpleStackPanel MinWidth="500" Spacing="12">
                    <ikw:SimpleStackPanel Spacing="3">
                        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_SubProfileRenamingDialogue_Name}" />
                        <TextBox
                            x:Name="SubProfileNameTextBox"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center" />
                    </ikw:SimpleStackPanel>
                </ikw:SimpleStackPanel>
            </ui:ContentDialog>

            <Border>
                <ikw:SimpleStackPanel
                    Name="StackPanel_Profiles"
                    IsEnabled="{Binding HasSelectedProfile, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                    Spacing="8">
                    <ikw:SimpleStackPanel Spacing="3">

                        <!--  Profile picker  -->
                        <Border
                            Padding="15,12,12,12"
                            Background="{DynamicResource ExpanderHeaderBackground}"
                            CornerRadius="{DynamicResource ControlCornerRadius}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" MinWidth="70" />
                                    <ColumnDefinition Width="5*" MinWidth="200" />
                                </Grid.ColumnDefinitions>

                                <DockPanel>
                                    <ui:FontIcon
                                        Name="ProfileIcon"
                                        HorizontalAlignment="Center"
                                        FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Glyph="&#xE7EE;" />

                                    <ikw:SimpleStackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_ProfileSelection}" />
                                        <TextBlock
                                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{l:Static resx:Resources.ProfilesPage_ProfileSelectionDesc}"
                                            TextWrapping="Wrap" />
                                    </ikw:SimpleStackPanel>
                                </DockPanel>

                                <Grid Grid.Column="1" Margin="12,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8*" MinWidth="140" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox
                                        Name="SelectMainProfileComboBox"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        ItemsSource="{Binding MainProfiles, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedItem="{Binding SelectedMainProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!--  Rename profile  -->
                                    <Button
                                        Name="RenameProfileButton"
                                        Grid.Column="1"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Command="{Binding RenameProfileCommand}"
                                        IsEnabled="{Binding IsProfileManagementEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe712;" />
                                    </Button>

                                    <!--  Create new profile  -->
                                    <Button
                                        Grid.Column="2"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Command="{Binding CreateProfileCommand}"
                                        Style="{DynamicResource AccentButtonStyle}">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe710;" />
                                    </Button>

                                    <!--  Delete profile  -->
                                    <Button
                                        Name="DeleteProfileButton"
                                        Grid.Column="3"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Command="{Binding DeleteProfileCommand}"
                                        IsEnabled="{Binding IsProfileManagementEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe738;" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <ui:InfoBar
                            Name="WarningInfoBar"
                            d:Visibility="Visible"
                            IsClosable="False"
                            IsOpen="{Binding HasWarning, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Message="{Binding WarningMessage, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Severity="Warning"
                            Visibility="{Binding HasWarning, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </ikw:SimpleStackPanel>

                    <!--  Profile details  -->
                    <Expander
                        Name="ProfileDetailsExpander"
                        d:IsExpanded="True"
                        IsEnabled="{Binding IsProfileDetailsExpanderEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="Profile details" />

                                <ui:DropDownButton
                                    Grid.Column="1"
                                    MinWidth="140"
                                    Margin="12,0,0,0"
                                    HorizontalAlignment="Right"
                                    Style="{DynamicResource AccentButtonStyle}"
                                    Visibility="Collapsed">
                                    <ui:DropDownButton.Content>
                                        <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="6">
                                            <ui:FontIcon FontSize="16" Glyph="&#xE768;" />
                                            <TextBlock Text="{l:Static resx:Resources.ProfilesPage_ProcessControl}" />
                                        </ikw:SimpleStackPanel>
                                    </ui:DropDownButton.Content>
                                    <ui:DropDownButton.Flyout>
                                        <ui:MenuFlyout Placement="BottomEdgeAlignedRight">
                                            <!--  Launch Process  -->
                                            <MenuItem
                                                Command="{Binding LaunchProfileProcessCommand}"
                                                Header="{l:Static resx:Resources.ProfilesPage_Play}"
                                                IsEnabled="{Binding CanLaunchProcess, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Glyph="&#xE768;" />
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <!--  Suspend Process  -->
                                            <MenuItem
                                                Command="{Binding SuspendProcessCommand}"
                                                Header="{l:Static resx:Resources.ProfilesPage_SuspendProcess}"
                                                IsEnabled="{Binding CanSuspendProcess, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Glyph="&#xE769;" />
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <!--  Resume Process  -->
                                            <MenuItem
                                                Command="{Binding ResumeProcessCommand}"
                                                Header="{l:Static resx:Resources.ProfilesPage_ResumeProcess}"
                                                IsEnabled="{Binding CanResumeProcess, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Glyph="&#xE768;" />
                                                </MenuItem.Icon>
                                            </MenuItem>

                                            <Separator />

                                            <!--  Kill Process  -->
                                            <MenuItem
                                                Command="{Binding KillProcessCommand}"
                                                Header="{l:Static resx:Resources.ProfilesPage_StopProcess}"
                                                IsEnabled="{Binding CanKillProcess, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Foreground="{DynamicResource SystemFillColorCriticalBrush}" Glyph="&#xE71A;" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ui:MenuFlyout>
                                    </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>

                                <Button
                                    Grid.Column="1"
                                    MinWidth="140"
                                    Margin="12,0,0,0"
                                    HorizontalAlignment="Right"
                                    Command="{Binding ToggleProfileProcessCommand}"
                                    IsEnabled="{Binding CanToggleProfileProcess, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{DynamicResource AccentButtonStyle}">
                                    <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="6">
                                        <ui:FontIcon FontSize="16">
                                            <ui:FontIcon.Style>
                                                <Style TargetType="ui:FontIcon">
                                                    <Setter Property="Glyph" Value="&#xE768;" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsProfileProcessRunning, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Value="True">
                                                            <Setter Property="Glyph" Value="&#xE71A;" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:FontIcon.Style>
                                        </ui:FontIcon>

                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{l:Static resx:Resources.ProfilesPage_Play}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsProfileProcessRunning, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Value="True">
                                                            <Setter Property="Text" Value="{l:Static resx:Resources.ProfilesPage_StopProcess}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </ikw:SimpleStackPanel>
                                </Button>
                            </Grid>
                        </Expander.Header>
                        <ikw:SimpleStackPanel Spacing="3">
                            <!--  Path  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="140" />
                                    <ColumnDefinition Width="10*" MinWidth="200" />
                                </Grid.ColumnDefinitions>

                                <DockPanel>
                                    <ui:FontIcon
                                        Height="40"
                                        FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Glyph="&#xED25;" />
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{l:Static resx:Resources.ProfilesPage_ProfilePath}" />
                                </DockPanel>

                                <DockPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBox
                                        Name="ProfilePathTextBox"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        BorderThickness="1"
                                        IsEnabled="False"
                                        IsReadOnly="True"
                                        Text="{Binding ProfilePath, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </Grid>

                            <!--  Arguments  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="140" />
                                    <ColumnDefinition Width="10*" MinWidth="200" />
                                </Grid.ColumnDefinitions>

                                <DockPanel>
                                    <ui:FontIcon
                                        Height="40"
                                        FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Glyph="&#xe712;" />
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{l:Static resx:Resources.ProfilesPage_ProfileArguments}" />
                                </DockPanel>

                                <DockPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBox
                                        Name="ProfileArgumentsTextBox"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        BorderThickness="1"
                                        Text="{Binding ProfileArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </Grid>

                            <!--  Launch string  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="140" />
                                    <ColumnDefinition Width="10*" MinWidth="200" />
                                </Grid.ColumnDefinitions>

                                <DockPanel>
                                    <ui:FontIcon
                                        Height="40"
                                        FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Glyph="&#xedb5;" />
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{l:Static resx:Resources.ProfilesPage_ProfileLaunchString}" />
                                </DockPanel>

                                <DockPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBox
                                        Name="ProfileLaunchStringTextBox"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        BorderThickness="1"
                                        Text="{Binding ProfileLaunchString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </Grid>

                            <!--  Sub Profiles  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="140" />
                                    <ColumnDefinition Width="10*" MinWidth="200" />
                                </Grid.ColumnDefinitions>

                                <DockPanel>
                                    <ui:FontIcon
                                        Height="40"
                                        FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Glyph="&#xE81E;" />
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{l:Static resx:Resources.ProfilesPage_SubProfiles}" />
                                </DockPanel>

                                <DockPanel Grid.Column="1" Margin="12,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8*" MinWidth="200" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox
                                            Name="SelectSubProfileComboBox"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            ItemsSource="{Binding SubProfiles, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectedItem="{Binding SelectedProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <ToggleButton
                                            Name="ToggleFavoriteButton"
                                            Grid.Column="1"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding ToggleFavoriteCommand}"
                                            IsChecked="{Binding IsLiked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <Grid>
                                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xEB52;" />
                                            </Grid>
                                        </ToggleButton>

                                        <Button
                                            Name="RenameSubProfileButton"
                                            Grid.Column="2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding RenameSubProfileCommand}">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe712;" />
                                        </Button>

                                        <Button
                                            Name="CreateSubProfileButton"
                                            Grid.Column="3"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding CreateSubProfileCommand}"
                                            Style="{DynamicResource AccentButtonStyle}">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe710;" />
                                        </Button>

                                        <Button
                                            Name="DeleteSubProfileButton"
                                            Grid.Column="4"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding DeleteSubProfileCommand}">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe738;" />
                                        </Button>
                                    </Grid>
                                </DockPanel>
                            </Grid>

                            <!--  Executables  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="140" />
                                    <ColumnDefinition Width="10*" MinWidth="200" />
                                </Grid.ColumnDefinitions>

                                <DockPanel>
                                    <ui:FontIcon
                                        Height="40"
                                        FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Glyph="&#xe8a5;" />
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{l:Static resx:Resources.ProfilesPage_ProfileExecutables}" />
                                </DockPanel>

                                <DockPanel Grid.Column="1" Margin="12,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8*" MinWidth="200" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding HasProfileExecutables, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            ItemsSource="{Binding ProfileExecutables, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectedIndex="{Binding ProfileExecutablesIdx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <Button
                                            Grid.Column="1"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding AddProfileExecutable}"
                                            Style="{DynamicResource AccentButtonStyle}">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe710;" />
                                        </Button>

                                        <Button
                                            Grid.Column="2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding RemoveProfileExecutable}"
                                            IsEnabled="{Binding HasProfileExecutables, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe738;" />
                                        </Button>
                                    </Grid>
                                </DockPanel>
                            </Grid>
                        </ikw:SimpleStackPanel>
                    </Expander>

                    <ikw:SimpleStackPanel
                        Name="ProfileDetails"
                        Spacing="3"
                        Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="8*" MinWidth="200" />
                            </Grid.ColumnDefinitions>

                            <ikw:SimpleStackPanel Spacing="3">
                                <Border
                                    Height="237"
                                    Padding="15,12,12,12"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    CornerRadius="{DynamicResource ControlCornerRadius}">
                                    <Border.Background>
                                        <ImageBrush
                                            AlignmentY="Center"
                                            ImageSource="{Binding Cover, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, NotifyOnTargetUpdated=True}"
                                            Stretch="UniformToFill" />
                                    </Border.Background>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <!--  fade in from 0->1 in 300ms  -->
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="0"
                                                        To="1"
                                                        Duration="0:0:0.3" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </ikw:SimpleStackPanel>

                            <Border
                                Grid.Column="1"
                                Margin="6,0,0,0"
                                Padding="15,12,12,12"
                                Background="{DynamicResource ExpanderHeaderBackground}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                CornerRadius="{DynamicResource ControlCornerRadius}" />
                        </Grid>
                    </ikw:SimpleStackPanel>

                    <!--  Global settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="Global settings" />
                    <ikw:SimpleStackPanel Name="StackGlobalSettings" Spacing="3">
                        <!--  Enable profile  -->
                        <ui:SettingsCard
                            Name="SettingsCardEnableProfile"
                            Description="{l:Static resx:Resources.ProfilesPage_EnableProfileDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_EnableProfile}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xE7EE;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ui:ToggleSwitch x:Name="EnableProfileToggle" IsOn="{Binding ProfileEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <ui:SettingsCard
                            Name="SettingsCardControllerPassthrough"
                            Description="{l:Static resx:Resources.ProfilesPage_WhitelistDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_Whitelist}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe7b3;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ui:ToggleSwitch x:Name="WhitelistToggle" IsOn="{Binding ProfileWhitelisted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>
                    </ikw:SimpleStackPanel>

                    <!--  Controller settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ControllerPage_ControllerSettings}" />
                    <ikw:SimpleStackPanel Spacing="3">

                        <!--  Controller layout  -->
                        <ui:SettingsCard
                            Name="SettingsCardControllerLayout"
                            Command="{Binding OpenControllerLayoutCommand}"
                            Description="{l:Static resx:Resources.ProfilesPage_ControllerLayoutDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_ControllerLayout}"
                            IsClickEnabled="True"
                            Tag="Navigation">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xE7FC;" />
                            </ui:SettingsCard.HeaderIcon>
                        </ui:SettingsCard>

                        <!--  Controller type  -->
                        <ui:SettingsCard Description="{l:Static resx:Resources.ProfilesPage_EmulatedControllerDesc}" Header="{l:Static resx:Resources.ProfilesPage_EmulatedController}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xE7FC;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ComboBox x:Name="EmulatedControllerComboBox" SelectedIndex="{Binding HIDModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Name="EmulatedControllerDefaultItem" Content="{l:Static resx:Resources.ProfilesPage_EmulatedControllerDefault}" />
                                <ComboBoxItem Name="EmulatedControllerXboxItem" Content="{l:Static resx:Resources.ProfilesPage_EmulatedControllerXbox}" />
                                <ComboBoxItem Name="EmulatedControllerDS4Item" Content="{l:Static resx:Resources.ProfilesPage_EmulatedControllerDS4}" />
                            </ComboBox>
                        </ui:SettingsCard>

                        <!--  Extended compatibility  -->
                        <ui:SettingsCard Description="{l:Static resx:Resources.ProfilesPage_WrapperDesc}" Header="{l:Static resx:Resources.ProfilesPage_Wrapper}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe90f;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ComboBox x:Name="WrapperComboBox" SelectedIndex="{Binding XInputPlusIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Name="WrapperDisabledItem" Content="{l:Static resx:Resources.ProfilesPage_Wrapper_Disabled}" />
                                <ComboBoxItem
                                    Name="WrapperInjectionItem"
                                    Content="{l:Static resx:Resources.ProfilesPage_Wrapper_Injection}"
                                    IsEnabled="{Binding IsWrapperInjectionEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBoxItem
                                    Name="WrapperRedirectionItem"
                                    Content="{l:Static resx:Resources.ProfilesPage_Wrapper_Redirection}"
                                    IsEnabled="{Binding IsWrapperRedirectionEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                            </ComboBox>
                        </ui:SettingsCard>
                    </ikw:SimpleStackPanel>

                    <!--  Power settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="Power settings" />
                    <ikw:SimpleStackPanel Name="PowerSettings" Spacing="3">

                        <ui:SettingsExpander
                            Description="{l:Static resx:Resources.ProfilesPage_PowerPresetDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_PowerPreset}"
                            IsExpanded="True">
                            <ui:SettingsExpander.HeaderIcon>
                                <ui:FontIcon Glyph="&#xec4a;" />
                            </ui:SettingsExpander.HeaderIcon>

                            <TextBlock
                                Name="SelectedPowerProfileName"
                                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{Binding SelectedPowerProfileName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:SettingsExpander.Items>
                                <ui:SettingsCard
                                    Command="{Binding OpenPowerProfileOnBatteryCommand}"
                                    Header="On battery"
                                    IsClickEnabled="True"
                                    Tag="Navigation">
                                    <ComboBox
                                        Name="PowerProfileOnBattery"
                                        DisplayMemberPath="Text"
                                        ItemContainerStyle="{StaticResource {x:Type ComboBoxItem}}"
                                        ItemsSource="{Binding ProfilePickerCollectionViewDC, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedIndex="{Binding SelectedPresetIndexDC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="Text" />
                                </ui:SettingsCard>

                                <ui:SettingsCard
                                    Command="{Binding OpenPowerProfilePluggedCommand}"
                                    Header="Plugged in"
                                    IsClickEnabled="True"
                                    Tag="Navigation">
                                    <ComboBox
                                        Name="PowerProfilePlugged"
                                        DisplayMemberPath="Text"
                                        ItemContainerStyle="{StaticResource {x:Type ComboBoxItem}}"
                                        ItemsSource="{Binding ProfilePickerCollectionViewAC, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedIndex="{Binding SelectedPresetIndexAC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="Text" />
                                </ui:SettingsCard>
                            </ui:SettingsExpander.Items>
                        </ui:SettingsExpander>
                    </ikw:SimpleStackPanel>

                    <!--  Graphics settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="Graphics settings" />
                    <ikw:SimpleStackPanel Name="GraphicsSettings" Spacing="3">

                        <!--  GPU Scaling  -->
                        <ui:SettingsExpander
                            Name="StackProfileGPUScaling"
                            d:IsEnabled="True"
                            d:IsExpanded="True"
                            Description="{l:Static resx:Resources.ProfilesPage_GPUScalingDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_GPUScaling}"
                            IsEnabled="{Binding HasGPUScalingSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <ui:SettingsExpander.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe9a6;" />
                            </ui:SettingsExpander.HeaderIcon>

                            <ui:ToggleSwitch x:Name="GPUScalingToggle" IsOn="{Binding GPUScalingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:SettingsExpander.Items>
                                <ui:SettingsCard Header="{l:Static resx:Resources.ProfilesPage_ScalingMode}" IsEnabled="{Binding GPUScalingEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox x:Name="GPUScalingComboBox" SelectedIndex="{Binding ScalingModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_ScalingMode_PreserveAspectRatio}" />
                                        <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_ScalingMode_FullPanel}" />
                                        <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_ScalingMode_Center}" IsEnabled="{Binding RSREnabled, Converter={StaticResource InvertBooleanConverter}}" />
                                    </ComboBox>
                                </ui:SettingsCard>
                            </ui:SettingsExpander.Items>
                        </ui:SettingsExpander>

                        <!--  (AMD: AFMF)  -->
                        <ui:SettingsCard
                            Name="StackProfileAFMF"
                            d:IsEnabled="True"
                            d:Visibility="Visible"
                            Description="{l:Static resx:Resources.ProfilesPage_AFMFDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_AFMF}"
                            IsEnabled="{Binding HasAFMFSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding IsAMDGPU, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe91b;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ui:ToggleSwitch x:Name="AFMFToggle" IsOn="{Binding AFMFEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  (AMD: RSR)  -->
                        <ui:SettingsExpander
                            Name="StackProfileRSR"
                            d:IsEnabled="True"
                            d:IsExpanded="True"
                            d:Visibility="Visible"
                            Description="{l:Static resx:Resources.ProfilesPage_RSRDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_RSR}"
                            IsEnabled="{Binding HasRSRSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding IsAMDGPU, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:SettingsExpander.HeaderIcon>
                                <ui:FontIcon Glyph="&#xE80A;" />
                            </ui:SettingsExpander.HeaderIcon>

                            <ui:ToggleSwitch x:Name="RSRToggle" IsOn="{Binding RSREnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:SettingsExpander.Items>
                                <ui:SettingsCard
                                    d:IsEnabled="True"
                                    Header="{l:Static resx:Resources.ProfilesPage_ResolutionScale}"
                                    IsEnabled="{Binding RSREnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                    <DockPanel>
                                        <TextBox
                                            Height="31"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            HorizontalContentAlignment="Center"
                                            IsReadOnly="True"
                                            Text="{Binding RSRValue, StringFormat={}{0:N0}%, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <Slider
                                            Name="RSRSlider"
                                            Width="200"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            AutoToolTipPrecision="0"
                                            IsMoveToPointEnabled="True"
                                            IsSnapToTickEnabled="True"
                                            LargeChange="5"
                                            Maximum="100"
                                            Minimum="0"
                                            SmallChange="1"
                                            TickFrequency="5"
                                            TickPlacement="BottomRight"
                                            ToolTip="{Binding Value, StringFormat={}{0:N0}%, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                            Value="{Binding RSRValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </ui:SettingsCard>
                            </ui:SettingsExpander.Items>
                        </ui:SettingsExpander>

                        <!--  Integer Scaling  -->
                        <ui:SettingsExpander
                            Name="StackProfileIS"
                            d:IsEnabled="True"
                            d:IsExpanded="True"
                            Description="{l:Static resx:Resources.ProfilesPage_ISDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_IS}"
                            IsEnabled="{Binding HasIntegerScalingSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <ui:SettingsExpander.HeaderIcon>
                                <ui:FontIcon Glyph="&#xeb3c;" />
                            </ui:SettingsExpander.HeaderIcon>

                            <ui:ToggleSwitch x:Name="IntegerScalingToggle" IsOn="{Binding IntegerScalingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:SettingsExpander.Items>
                                <ui:SettingsCard
                                    d:IsEnabled="True"
                                    Header="{l:Static resx:Resources.ProfilesPage_ResolutionScale}"
                                    IsEnabled="{Binding IntegerScalingEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                                    <ComboBox
                                        Name="IntegerScalingComboBox"
                                        ItemsSource="{Binding IntegerScalingDividers}"
                                        SelectedIndex="{Binding IntegerScalingDividerIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </ui:SettingsCard>
                            </ui:SettingsExpander.Items>
                        </ui:SettingsExpander>

                        <!--  RIS  -->
                        <ui:SettingsExpander
                            Name="StackProfileRIS"
                            d:IsEnabled="True"
                            d:IsExpanded="True"
                            Description="{l:Static resx:Resources.ProfilesPage_ImageSharpeningDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_ImageSharpening}"
                            IsEnabled="{Binding HasGPUScalingSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <ui:SettingsExpander.HeaderIcon>
                                <ui:FontIcon Glyph="&#xed63;" />
                            </ui:SettingsExpander.HeaderIcon>

                            <ui:ToggleSwitch x:Name="RISToggle" IsOn="{Binding RISEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:SettingsExpander.Items>
                                <ui:SettingsCard
                                    d:IsEnabled="True"
                                    Header="{l:Static resx:Resources.ProfilesPage_SharpeningScale}"
                                    IsEnabled="{Binding RISEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                    <DockPanel>
                                        <TextBox
                                            Height="31"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            HorizontalContentAlignment="Center"
                                            IsReadOnly="True"
                                            Text="{Binding RISValue, StringFormat={}{0:N0}%, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <Slider
                                            x:Name="RISSlider"
                                            Width="200"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            AutoToolTipPrecision="0"
                                            IsMoveToPointEnabled="True"
                                            IsSnapToTickEnabled="True"
                                            LargeChange="5"
                                            Maximum="100"
                                            Minimum="0"
                                            SmallChange="1"
                                            TickFrequency="5"
                                            TickPlacement="BottomRight"
                                            ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                            Value="{Binding RISValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </ui:SettingsCard>
                            </ui:SettingsExpander.Items>
                        </ui:SettingsExpander>

                        <!--  Framerate Limit  -->
                        <ui:SettingsCard
                            Name="StackProfileFramerate"
                            d:IsEnabled="True"
                            Description="{l:Static resx:Resources.ProfilesPage_FramerateLimitDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_FramerateLimit}"
                            IsEnabled="{Binding IsRTSSReady, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe8b2;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ComboBox
                                Name="FramerateLimitComboBox"
                                ItemsSource="{Binding FramerateLimits}"
                                SelectedItem="{Binding SelectedFrameLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>
                    </ikw:SimpleStackPanel>

                    <!--  Library settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_LibrarySettings}" />
                    <ikw:SimpleStackPanel Spacing="3">
                        <!--  Library settings  -->
                        <ui:SettingsCard
                            Name="LibrarySettings"
                            HorizontalAlignment="Stretch"
                            Command="{Binding DisplayLibrary}"
                            Header="{l:Static resx:Resources.ProfilesPage_LibraryDownload}"
                            IsClickEnabled="True"
                            IsEnabled="{Binding IsLibraryConnected, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Tag="Navigation">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xE8F1;" />
                            </ui:SettingsCard.HeaderIcon>
                        </ui:SettingsCard>

                        <ui:SettingsCard Description="{l:Static resx:Resources.ProfilesPage_ShowInLibraryDesc}" Header="{l:Static resx:Resources.ProfilesPage_ShowInLibrary}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe7b3;" />
                            </ui:SettingsCard.HeaderIcon>
                            <ui:ToggleSwitch x:Name="ShowInLibraryToggle" IsOn="{Binding ShowInLibrary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>
                    </ikw:SimpleStackPanel>

                    <!--  Motion control settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_MotionControlSettings}" />
                    <ikw:SimpleStackPanel Spacing="3">
                        <!--  Motion control settings  -->
                        <ui:SettingsExpander
                            Name="MotionSettings"
                            d:IsExpanded="True"
                            Description="{l:Static resx:Resources.ProfilesPage_MotionControlSettingsDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_MotionControlSettings}">
                            <ui:SettingsExpander.HeaderIcon>
                                <ui:FontIcon Glyph="&#xE8B4;" />
                            </ui:SettingsExpander.HeaderIcon>

                            <ui:SettingsExpander.Items>
                                <!--  Gyrometer multiplier  -->
                                <ui:SettingsCard Description="{l:Static resx:Resources.ProfilesPage_GyrometerMultiplierDesc}" Header="{l:Static resx:Resources.ProfilesPage_GyrometerMultiplier}">
                                    <DockPanel>
                                        <TextBox
                                            Height="31"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            HorizontalContentAlignment="Center"
                                            IsReadOnly="True"
                                            Text="{Binding GyroMultiplier, StringFormat={}{0:N1}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Slider
                                            x:Name="GyroMultiplierSlider"
                                            Width="200"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            AutoToolTipPrecision="1"
                                            IsMoveToPointEnabled="True"
                                            IsSnapToTickEnabled="True"
                                            Maximum="3"
                                            Minimum="0.1"
                                            TickFrequency="0.1"
                                            TickPlacement="BottomRight"
                                            ToolTip="{Binding Value, StringFormat=N1, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                            Value="{Binding GyroMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </ui:SettingsCard>

                                <!--  Accelerometer multiplier  -->
                                <ui:SettingsCard Description="{l:Static resx:Resources.ProfilesPage_AccelerometerMultiplierDesc}" Header="{l:Static resx:Resources.ProfilesPage_AccelerometerMultiplier}">
                                    <DockPanel>
                                        <TextBox
                                            Height="31"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            HorizontalContentAlignment="Center"
                                            IsReadOnly="True"
                                            Text="{Binding AcceleroMultiplier, StringFormat={}{0:N1}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Slider
                                            x:Name="AcceleroMultiplierSlider"
                                            Width="200"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            AutoToolTipPrecision="1"
                                            IsMoveToPointEnabled="True"
                                            IsSnapToTickEnabled="True"
                                            LargeChange="1"
                                            Maximum="3"
                                            Minimum="0.1"
                                            TickFrequency="0.1"
                                            TickPlacement="BottomRight"
                                            ToolTip="{Binding Value, StringFormat=N1, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                            Value="{Binding AcceleroMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </ui:SettingsCard>

                                <!--  Gyro steering axis  -->
                                <ui:SettingsCard Description="{l:Static resx:Resources.ProfilesPage_GyroSteeringAxisDesc}" Header="{l:Static resx:Resources.ProfilesPage_GyroSteeringAxis}">
                                    <ComboBox x:Name="GyroSteeringComboBox" SelectedIndex="{Binding SteeringAxisIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem>
                                            <!--  Roll = 0  -->
                                            <ikw:SimpleStackPanel
                                                HorizontalAlignment="Left"
                                                Orientation="Horizontal"
                                                Spacing="3">
                                                <ui:FontIcon Glyph="&#xE8B4;" />
                                                <Label Content="{l:Static resx:Resources.ProfilesPage_Roll}" />
                                            </ikw:SimpleStackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <!--  Yaw = 1  -->
                                            <ikw:SimpleStackPanel
                                                HorizontalAlignment="Left"
                                                Orientation="Horizontal"
                                                Spacing="3">
                                                <ui:FontIcon Glyph="&#xE8B4;" />
                                                <Label Content="{l:Static resx:Resources.ProfilesPage_Yaw}" />
                                            </ikw:SimpleStackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <!--  Auto = 2  -->
                                            <ikw:SimpleStackPanel
                                                HorizontalAlignment="Left"
                                                Orientation="Horizontal"
                                                Spacing="3">
                                                <ui:FontIcon Glyph="&#xE8B4;" />
                                                <Label Content="{l:Static resx:Resources.ProfilesPage_RollYawAuto}" />
                                            </ikw:SimpleStackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                </ui:SettingsCard>

                                <ui:SettingsCard ContentAlignment="Left">
                                    <CheckBox
                                        Name="InvertHorizontalCheckBox"
                                        Content="{l:Static resx:Resources.ProfilesPage_InvertHorizontalAxis}"
                                        IsChecked="{Binding MotionInvertHorizontal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </ui:SettingsCard>

                                <ui:SettingsCard ContentAlignment="Left">
                                    <CheckBox
                                        Name="InvertVerticalCheckBox"
                                        Content="{l:Static resx:Resources.ProfilesPage_InvertVerticalAxis}"
                                        IsChecked="{Binding MotionInvertVertical, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </ui:SettingsCard>
                            </ui:SettingsExpander.Items>
                        </ui:SettingsExpander>

                        <!--  TODO: Move this to layout page  -->
                        <ui:SettingsCard
                            Name="MotionControlAdditional"
                            Command="{Binding OpenAdditionalSettingsCommand}"
                            Header="{l:Static resx:Resources.ProfilesPage_AdditionalSettings}"
                            IsClickEnabled="True"
                            Tag="Navigation" />
                    </ikw:SimpleStackPanel>

                    <!--  Window settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_WindowsSettings}" />
                    <ikw:SimpleStackPanel Spacing="3">
                        <ui:SettingsExpander d:IsExpanded="True" Header="Sleep and hibernate">
                            <ui:SettingsExpander.Items>
                                <!--  Suspend on overlay  -->
                                <ui:SettingsCard ContentAlignment="Left">
                                    <CheckBox
                                        Name="SuspendOnOverlayCheckBox"
                                        Content="{l:Static resx:Resources.ProfilesPage_SuspendOnOverlay}"
                                        IsChecked="{Binding SuspendOnQT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </ui:SettingsCard>

                                <!--  Suspend on sleep/resume  -->
                                <ui:SettingsCard ContentAlignment="Left">
                                    <CheckBox
                                        Name="SuspendOnSleepCheckBox"
                                        Content="{l:Static resx:Resources.ProfilesPage_SuspendOnSleep}"
                                        IsChecked="{Binding SuspendOnSleep, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </ui:SettingsCard>
                            </ui:SettingsExpander.Items>
                        </ui:SettingsExpander>

                        <ui:SettingsExpander
                            Description="{l:Static resx:Resources.ProfilesPage_WindowsSettingsDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_WindowsSettings}"
                            IsEnabled="{Binding HasAnyWindows, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            IsExpanded="{Binding HasAnyWindows, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{Binding AllWindows}">

                            <ui:SettingsExpander.HeaderIcon>
                                <ui:FontIcon Glyph="&#xf7ed;" />
                            </ui:SettingsExpander.HeaderIcon>

                            <ui:SettingsExpander.ItemTemplate>
                                <DataTemplate>
                                    <ui:SettingsCard Header="{Binding Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ikw:SimpleStackPanel
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal"
                                            Spacing="3">

                                            <ComboBox SelectedIndex="{Binding TargetDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBoxItem>Current</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay1, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY1</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay2, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY2</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay3, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY3</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay4, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY4</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay5, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY5</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay6, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY6</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay7, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY7</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay8, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY8</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay9, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY9</ComboBoxItem>
                                                <ComboBoxItem IsEnabled="{Binding HasDisplay10, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">\\.\DISPLAY10</ComboBoxItem>
                                            </ComboBox>

                                            <ComboBox SelectedIndex="{Binding TargetWindowPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBoxItem>Center</ComboBoxItem>
                                                <ComboBoxItem>Left</ComboBoxItem>
                                                <ComboBoxItem>Top</ComboBoxItem>
                                                <ComboBoxItem>Right</ComboBoxItem>
                                                <ComboBoxItem>Bottom</ComboBoxItem>
                                                <ComboBoxItem>TopLeft</ComboBoxItem>
                                                <ComboBoxItem>TopRight</ComboBoxItem>
                                                <ComboBoxItem>BottomRight</ComboBoxItem>
                                                <ComboBoxItem>BottomLeft</ComboBoxItem>
                                                <ComboBoxItem>Maximize</ComboBoxItem>
                                            </ComboBox>

                                            <CheckBox IsChecked="{Binding Borderless, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">Borderless</CheckBox>
                                        </ikw:SimpleStackPanel>
                                    </ui:SettingsCard>
                                </DataTemplate>
                            </ui:SettingsExpander.ItemTemplate>
                        </ui:SettingsExpander>
                    </ikw:SimpleStackPanel>

                    <!--  Compatibility settings  -->
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_Compatibility}" />
                    <ikw:SimpleStackPanel Spacing="3">
                        <!--  Fullscreen optimizations  -->
                        <ui:SettingsCard Header="{l:Static resx:Resources.ProfilesPage_Compatibility_Fullscreen}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe740;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ui:ToggleSwitch x:Name="UseFullscreenOptimizations" IsOn="{Binding FullScreenOptimization, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  High DPI awareness  -->
                        <ui:SettingsCard Header="{l:Static resx:Resources.ProfilesPage_Compatibility_HighDPI}">
                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon Glyph="&#xe799;" />
                            </ui:SettingsCard.HeaderIcon>

                            <ui:ToggleSwitch x:Name="UseHighDPIAwareness" IsOn="{Binding HighDPIAware, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>
                    </ikw:SimpleStackPanel>
                </ikw:SimpleStackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
