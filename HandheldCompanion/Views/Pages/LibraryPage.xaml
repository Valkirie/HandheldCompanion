<Page
    x:Class="HandheldCompanion.Views.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:HandheldCompanion.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:emoji="http://schemas.inkore.net/lib/ui/wpf/emojis"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:l="clr-namespace:HandheldCompanion.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:HandheldCompanion.Properties"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels"
    Name="About"
    Title="{l:Static resx:Resources.MainWindow_navLibrary}"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:LibraryPageViewModel}"
    d:DesignHeight="1000"
    d:DesignWidth="1000"
    KeepAlive="True"
    mc:Ignorable="d">

    <Grid Margin="20">
        <ikw:SimpleStackPanel Spacing="12">
            <ikw:SimpleStackPanel Spacing="3">
                <ui:SettingsExpander
                    d:IsExpanded="True"
                    Description="Manage library settings"
                    Header="Library">
                    <ui:SettingsExpander.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE7BC;" />
                    </ui:SettingsExpander.HeaderIcon>

                    <ikw:SimpleStackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="3">
                        <Button
                            Height="31"
                            VerticalAlignment="Bottom"
                            Command="{Binding ToggleSortCommand}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AccentButtonStyle}" TargetType="Button">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <ui:FontIcon
                                                Height="28"
                                                VerticalAlignment="Center"
                                                Icon="{x:Static ui:FluentSystemIcons.ArrowSortDownLines_24_Regular}" />
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SortAscending}" Value="False">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <ui:FontIcon
                                                        Height="28"
                                                        VerticalAlignment="Center"
                                                        Icon="{x:Static ui:FluentSystemIcons.ArrowSortUpLines_24_Regular}" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Height="31"
                            VerticalAlignment="Bottom"
                            Command="{Binding ToggleViewModeCommand}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AccentButtonStyle}" TargetType="Button">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <ui:FontIcon
                                                Height="28"
                                                VerticalAlignment="Center"
                                                Icon="{x:Static ui:FluentSystemIcons.AppsListDetail_24_Filled}" />
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="1">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <ui:FontIcon
                                                        Height="28"
                                                        VerticalAlignment="Center"
                                                        Icon="{x:Static ui:FluentSystemIcons.Grid_20_Filled}" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="2">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <ui:FontIcon
                                                        Height="28"
                                                        VerticalAlignment="Center"
                                                        Icon="{x:Static ui:FluentSystemIcons.GridKanban_20_Filled}" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </ikw:SimpleStackPanel>

                    <ui:SettingsExpander.Items>
                        <ui:SettingsCard Header="Download metadata and artworks">
                            <Button Command="{Binding RefreshMetadataCommand}" IsEnabled="{Binding IsLibraryConnected, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">Download</Button>
                        </ui:SettingsCard>
                        <ui:SettingsCard Header="Update game library">
                            <ui:DropDownButton Content="Update">
                                <ui:DropDownButton.Flyout>
                                    <ui:MenuFlyout Placement="Bottom">
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="All"
                                            Header="All" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="BattleNet"
                                            Header="Battle.net" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="Epic"
                                            Header="Epic" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="GOG"
                                            Header="GOG GALAXY" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="Origin"
                                            Header="Origin" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="EA Desktop"
                                            Header="EA Desktop" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="Riot"
                                            Header="Riot Games" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="Rockstar"
                                            Header="Rockstar" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="Steam"
                                            Header="Steam" />
                                        <MenuItem
                                            Command="{Binding ScanLibraryCommand}"
                                            CommandParameter="Ubisoft"
                                            Header="Ubisoft Connect" />
                                    </ui:MenuFlyout>
                                </ui:DropDownButton.Flyout>
                            </ui:DropDownButton>
                        </ui:SettingsCard>
                    </ui:SettingsExpander.Items>
                </ui:SettingsExpander>
            </ikw:SimpleStackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:AutoSuggestBox
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    PlaceholderText="Search library..."
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ui:AutoSuggestBox.QueryIcon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Search}" />
                    </ui:AutoSuggestBox.QueryIcon>
                </ui:AutoSuggestBox>
                <ComboBox
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    SelectedIndex="{Binding SortTarget}">
                    <ComboBoxItem Content="Alphabetic" />
                    <ComboBoxItem Content="Platform" />
                    <ComboBoxItem Content="Recently added" />
                    <ComboBoxItem Content="Recently played" />
                </ComboBox>
            </Grid>

            <!--  Unified Library (Favorites shown with wide template, others with grid/list template)  -->
            <!--  Content is always visible so cards render incrementally as they arrive.  -->
            <!--  The spinner overlays the content via Panel.ZIndex inside the Grid wrapper.  -->
            <Grid>
                <ikw:SimpleStackPanel Spacing="8">
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="Library" />

                    <ItemsControl
                        x:Name="profilesRepeater"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding ProfilesView}"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                        <Setter Property="Margin" Value="0,0,0,6" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                        <Setter Property="controls:JustifiedWrapPanel.ItemSpan" Value="3" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.IsWideView, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                        <Setter Property="controls:JustifiedWrapPanel.ItemSpan" Value="3" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl
                                    Margin="0"
                                    HorizontalAlignment="Stretch"
                                    Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <!--  Wide template for favorites (same height, double width)  -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsLiked}" Value="True" />
                                                        <Condition Binding="{Binding DataContext.IsGridView, RelativeSource={RelativeSource AncestorType=Page}}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="ContentTemplate" Value="{StaticResource LibraryTemplateWide}" />
                                                </MultiDataTrigger>
                                                <!--  Grid template for non-favorites (when in grid view)  -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsLiked}" Value="False" />
                                                        <Condition Binding="{Binding DataContext.IsGridView, RelativeSource={RelativeSource AncestorType=Page}}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="ContentTemplate" Value="{StaticResource LibraryTemplate}" />
                                                </MultiDataTrigger>
                                                <!--  List template for non-favorites (when in list view)  -->
                                                <DataTrigger Binding="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource LibraryTemplateList}" />
                                                    <Setter Property="Height" Value="64" />
                                                </DataTrigger>
                                                <!--  Wide view: all items use wide template regardless of IsLiked  -->
                                                <DataTrigger Binding="{Binding DataContext.IsWideView, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource LibraryTemplateWide}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ikw:SimpleStackPanel>

                <!--  Spinner overlays the card grid while the initial load is in progress  -->
                <ui:ProgressRing
                    Width="60"
                    Height="60"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Panel.ZIndex="1"
                    IsActive="True"
                    IsIndeterminate="True"
                    Visibility="{Binding IsInitializing, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </ikw:SimpleStackPanel>
    </Grid>
</Page>